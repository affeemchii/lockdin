{% liquid
  assign selling_plan_groups = product.selling_plan_groups
  assign has_deposit_plan = false
  assign deposit_plan_group = nil

  for group in selling_plan_groups
    assign group_name_downcase = group.name | downcase

    comment
      Check 1: group name contains 'deposit' or 'lockdin'
      These match merchant-named plans with obvious names
    endcomment
    if group_name_downcase contains 'deposit' or group_name_downcase contains 'lockdin'
      assign has_deposit_plan = true
      assign deposit_plan_group = group
      break
    endif

    comment
      Check 2: any option inside the group is named 'Deposit Option'
      This is the most reliable check — lockdIn always creates
      selling plans with options[0].name = 'Deposit Option'
      This catches plans with any merchant-chosen name like 'AA'
    endcomment
    for option in group.options
      assign option_name_downcase = option.name | downcase
      if option_name_downcase contains 'deposit option'
        assign has_deposit_plan = true
        assign deposit_plan_group = group
        break
      endif
    endfor

    if has_deposit_plan
      break
    endif
  endfor
%}

{% if has_deposit_plan and deposit_plan_group != nil %}
  {% assign selling_plan = deposit_plan_group.selling_plans | first %}
  {% if selling_plan != nil %}
    <div
      class="lockdin-deposit-widget"
      data-selling-plan-id="{{ selling_plan.id }}"
      style="
        margin: 16px 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      "
    >
      <!-- Deposit Options Container -->
      <div style="
        border: 1px solid #e1e3e5;
        border-radius: 8px;
        overflow: hidden;
        background: #ffffff;
      ">

        <!-- Header -->
        <div style="
          padding: 12px 16px;
          background: #f6f6f7;
          border-bottom: 1px solid #e1e3e5;
          display: flex;
          align-items: center;
          gap: 8px;
        ">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="8" width="14" height="10" rx="2" stroke="#202223" stroke-width="1.5" fill="none"/>
            <path d="M7 8V6C7 3.791 8.343 2 10 2C11.657 2 13 3.791 13 6V8" stroke="#202223" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="10" cy="13" r="1.5" fill="#202223"/>
          </svg>
          <span style="font-size: 13px; font-weight: 600; color: #202223;">
            Flexible Payment Options
          </span>
        </div>

        <!-- Pay Deposit Option -->
        <label
          class="lockdin-option lockdin-deposit-option"
          style="
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 16px;
            cursor: pointer;
            border-bottom: 1px solid #e1e3e5;
            transition: background 0.15s ease;
          "
        >
          <input
            type="radio"
            name="lockdin-payment-option"
            value="deposit"
            class="lockdin-radio"
            checked
            style="margin-top: 2px; accent-color: #202223;"
            data-selling-plan-id="{{ selling_plan.id }}"
          />
          <div style="flex: 1;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
              <span style="font-size: 14px; font-weight: 600; color: #202223;">
                Pay Deposit Now
              </span>
              {% if selling_plan.checkout_charge.value_type == 'percentage' %}
                <span style="
                  background: {{ block.settings.badge_color }};
                  color: #ffffff;
                  font-size: 11px;
                  font-weight: 700;
                  padding: 2px 8px;
                  border-radius: 20px;
                ">
                  {{ selling_plan.checkout_charge.value }}% today
                </span>
              {% endif %}
            </div>
            <p style="font-size: 13px; color: #6d7175; margin: 0;">
              {{ selling_plan.description | default: 'Secure your order with a deposit. Pay the remaining balance later.' }}
            </p>
            {% if selling_plan.checkout_charge.value_type == 'percentage' %}
              <p style="font-size: 12px; color: #6d7175; margin: 6px 0 0 0;">
                Pay {{ selling_plan.checkout_charge.value }}% (
                <span class="lockdin-deposit-amount">
                  {{- product.selected_or_first_available_variant.price | times: selling_plan.checkout_charge.value | divided_by: 100 | money -}}
                </span>
                ) now — remaining balance due on Cash on Delivery.
              </p>
            {% elsif selling_plan.checkout_charge.value_type == 'price' %}
              <p style="font-size: 12px; color: #6d7175; margin: 6px 0 0 0;">
                Pay {{ selling_plan.checkout_charge.value | money }} now — remaining balance due on Cash on Delivery.
              </p>
            {% endif %}
          </div>
        </label>

        <!-- Pay in Full Option -->
        <label
          class="lockdin-option lockdin-full-option"
          style="
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 16px;
            cursor: pointer;
            transition: background 0.15s ease;
          "
        >
          <input
            type="radio"
            name="lockdin-payment-option"
            value="full"
            class="lockdin-radio"
            style="margin-top: 2px; accent-color: #202223;"
          />
          <div style="flex: 1;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
              <span style="font-size: 14px; font-weight: 600; color: #202223;">
                Pay in Full
              </span>
              <span style="font-size: 13px; color: #202223; font-weight: 600;">
                {{ product.selected_or_first_available_variant.price | money }}
              </span>
            </div>
            <p style="font-size: 13px; color: #6d7175; margin: 0;">
              Pay the full amount now and get instant confirmation.
            </p>
          </div>
        </label>

      </div>

      <!-- Hidden selling plan input - this is what Shopify reads -->
      <input
        type="hidden"
        id="lockdin-selling-plan-input"
        name="selling_plan"
        value="{{ selling_plan.id }}"
      />

    </div>

    <script>
      (function() {
        var widget = document.querySelector('.lockdin-deposit-widget');
        if (!widget) return;

        var radios = widget.querySelectorAll('.lockdin-radio');
        var options = widget.querySelectorAll('.lockdin-option');

        // The selling plan GID from Shopify looks like:
        // gid://shopify/SellingPlan/123456789
        // Shopify cart endpoint needs only the numeric part: 123456789
        // We extract it by splitting on the last slash
        var rawSellingPlanId = widget.dataset.sellingPlanId || '';
        var numericSellingPlanId = rawSellingPlanId.split('/').pop();

        // Target the theme's OWN selling_plan input that lives 
        // inside the cart form. Our widget is outside the form 
        // so we cannot use our own hidden input for submission.
        // The theme's input is always: input[name="selling_plan"]
        // inside a product form.
        var nativeSellingPlanInput = document.querySelector(
          'form[action="/cart/add"] input[name="selling_plan"]'
        );

        function updateSelection(value) {
          // Update visual highlight on selected option
          options.forEach(function(option) {
            option.style.background = '#ffffff';
          });

          var selectedLabel = widget.querySelector(
            'label:has(input[value="' + value + '"])'
          );
          if (selectedLabel) {
            selectedLabel.style.background = '#f6f6f7';
          }

          // Write to the theme's native selling_plan input
          // which IS inside the cart form and will be submitted
          if (nativeSellingPlanInput) {
            if (value === 'deposit') {
              // Set numeric selling plan ID so Shopify applies deposit
              nativeSellingPlanInput.value = numericSellingPlanId;
            } else {
              // Empty value means no selling plan = full price
              nativeSellingPlanInput.value = '';
            }
            // Dispatch change event so theme JS stays in sync
            var changeEvent = new Event('change', { bubbles: true });
            nativeSellingPlanInput.dispatchEvent(changeEvent);
          }
        }

        radios.forEach(function(radio) {
          radio.addEventListener('change', function() {
            updateSelection(this.value);
          });
        });

        // Set deposit as default selection on page load
        updateSelection('deposit');

        // Hide Shopify's native selling plan selector UI
        // after theme JS has had time to initialise (400ms)
        setTimeout(function() {
          var nativeInput = document.querySelector(
            'input[name="purchase_option"]'
          );
          if (nativeInput) {
            var wrapper = nativeInput.closest('fieldset')
              || nativeInput.closest('purchase-options-radio-component')
              || nativeInput.closest('.product-form__input')
              || nativeInput.parentElement.parentElement;
            if (wrapper) {
              wrapper.style.display = 'none';
            }
          }
        }, 400);

      })();
    </script>

  {% endif %}
{% endif %}

{% schema %}
{
  "name": "lockdIn Deposit Options",
  "target": "section",
  "settings": [
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge color",
      "default": "#ff9900"
    },
    {
      "type": "checkbox",
      "id": "show_full_price_option",
      "label": "Show pay in full option",
      "default": true
    }
  ]
}
{% endschema %}
